	del -> output_files [color="#94A3B8" constraint=false fontsize=8 style=dashed]
	estate [label=<<b>EncounterState (Pydantic v2)</b> — shared across all nodes   <font point-size="9">encounter_id · provider_id · recording_mode (AMBIENT | DICTATION) · context_packet · audio_segments · transcript · generated_note · final_note · delivery_result · errors[] · EncounterMetrics</font>> fillcolor="#C7D2FE" fontcolor="#1E1B4B" fontname=Helvetica fontsize=10 height=0.50 shape=rectangle style=filled width=8.0]
	del -> estate [style=invis]
	reg [label=<<b>EngineRegistry</b>  (mcp_servers/registry.py)<br/><font point-size="9">get_asr(provider_id, use_lora=False) · get_llm() · get_ehr() · get_with_failover() · health_check_all() · Config: config/engines.yaml — zero-code engine swap</font>> fillcolor="#00B27A" fontcolor=white fontname="Helvetica-Bold" fontsize=11 margin="0.15,0.10" shape=box style="filled,rounded" width=9.0]
	estate -> reg [style=invis]
	qual_trend [label=<<b>Quality Progress  (v1 → v6, judge: llama3.1:latest, 22 gold samples)</b><br/><font point-size="9">v1  Session 4    basic end-to-end pipeline                     3.50 / 5.0    v2  Session 5    templates + specialty dictionaries             4.30 / 5.0<br/>v3  Session 7    EHR patient context + demographics             4.34 / 5.0    v4  Session 8    provider profiles + vocab + style directives   4.38 / 5.0<br/>v5  Session 10   ASR inference knobs + LoRA evaluation          4.35 / 5.0    <b>v6  Session 10c  qwen2.5:14b · two-pass eval                4.44 / 5.0  ✓</b></font>> fillcolor="#F1F5F9" fontcolor="#1C1917" fontname=Helvetica fontsize=10 margin="0.15,0.10" shape=box style="filled,rounded" width=12.0]
	reg -> qual_trend [style=invis]
	subgraph cluster_ui {
		color="#0369A1" fillcolor="#EFF6FF" fontname="Helvetica-Bold" fontsize=12 label="  API + WEB UI  " labeljust=l labelloc=t penwidth=2 style=filled
		api [label=<<b>FastAPI Backend  (api/)  ·  :8000</b><br/><font point-size="9">GET /encounters/{id}/transcript · /note · /audio · /comparison · /quality</font><br/><font point-size="9">POST /encounters · POST /{id}/upload  (triggers pipeline async)</font><br/><font point-size="9">GET /providers · GET /quality/aggregate · /samples · /dimensions</font><br/><font point-size="9">WS /ws/encounters/{id}  — real-time stage progress events</font><br/><font point-size="9">Data: output/ directory tree (no DB required)</font>> fillcolor="#0369A1" fontcolor=white fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=5.5]
		web [label=<<b>Next.js Web App  (client/web/)  ·  :3000</b><br/><font point-size="9">Dashboard: KPI cards · quality trend (Recharts) · encounters table</font><br/><font point-size="9">Samples: filterable by version / mode / score range</font><br/><font point-size="9">Sample Detail  6 tabs:  Transcript (audio player + v-picker)</font><br/><font point-size="9">  Clinical Note (Markdown + v-picker) · Comparison (gold vs gen)</font><br/><font point-size="9">  Gold Standard · Quality Scores · Compare Versions (LCS diff)</font><br/><font point-size="9">Providers: quality history · Upload: drag-and-drop MP3/WAV</font>> fillcolor="#0369A1" fontcolor=white fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=5.5]
		{
			rank=same
		}
		web -> api [label="REST + WebSocket" fontsize=9]
	}
	qual_trend -> api [style=invis]
}
