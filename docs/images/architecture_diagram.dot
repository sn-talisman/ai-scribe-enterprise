		output_files [label=<<b>Output Files  (output/)</b><br/><font point-size="9">audio_transcript_v{N}.txt — standalone per version</font><br/><font point-size="9">generated_note_v{N}.md — clinical note Markdown</font><br/><font point-size="9">comparison_v{N}.md — gold vs generated side-by-side</font><br/><font point-size="9">quality_report_v{N}.md · batch_report_v{N}.md</font>> color="#0369A1" fillcolor="#F8FAFC" fontcolor="#1C1917" fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
	}
