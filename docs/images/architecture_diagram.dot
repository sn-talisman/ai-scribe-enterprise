digraph ai_scribe {
	bgcolor=white compound=true dpi=150 fontname=Helvetica fontsize=12 nodesep=0.40 pad=0.5 rankdir=TB ranksep=0.75 ratio=fill size="14,20!"
	subgraph cluster_pipe {
		color="#1E1B4B" fillcolor="#EEF2FF" fontname="Helvetica-Bold" fontsize=12 label="§1  LANGGRAPH PIPELINE  (orchestrator/)" labeljust=l labelloc=t penwidth=2 style=filled
		{
			rank=same
			ctx [label=<<b>CONTEXT</b><br/><font point-size="8">StubEHRServer<br/>patient_context.yaml</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=10 height=0.52 margin="0.10,0.07" shape=box style="filled,rounded" width=2.0]
			cap [label=<<b>CAPTURE</b><br/><font point-size="8">audio_segments<br/>future: VAD + denoise</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=10 height=0.52 margin="0.10,0.07" shape=box style="filled,rounded" width=2.0]
			tx [label=<<b>TRANSCRIBE</b><br/><font point-size="8">WhisperX large-v3<br/>faster-whisper + pyannote</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=10 height=0.52 margin="0.10,0.07" shape=box style="filled,rounded" width=2.0]
			asr_r [label=<<font point-size="8">asr_router</font>> fillcolor="#312E81" fontcolor=white height=0.52 shape=diamond style=filled width=0.85]
			note [label=<<b>NOTE</b><br/><font point-size="8">OllamaServer<br/>qwen2.5:14b</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=10 height=0.52 margin="0.10,0.07" shape=box style="filled,rounded" width=2.2]
			llm_r [label=<<font point-size="8">llm_router</font>> fillcolor="#312E81" fontcolor=white height=0.52 shape=diamond style=filled width=0.85]
			rev [label=<<b>REVIEW</b><br/><font point-size="8">HITL Review<br/>auto-approve stub</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=10 height=0.52 margin="0.10,0.07" shape=box style="filled,rounded" width=2.0]
			del [label=<<b>DELIVERY</b><br/><font point-size="8">EHR push<br/>clipboard stub</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=10 height=0.52 margin="0.10,0.07" shape=box style="filled,rounded" width=2.0]
		}
		ctx -> cap [label=context_packet fontsize=8]
		cap -> tx [label=audio_segments fontsize=8]
		tx -> asr_r
		asr_r -> note [label="conf≥0.40" fontsize=8]
		note -> llm_r
		llm_r -> rev [label="conf≥0.50" fontsize=8]
		rev -> del [label=approved fontsize=8]
		estate [label=<<b>EncounterState (Pydantic v2)</b> — shared across all nodes<br/><font point-size="8">encounter_id  ·  provider_id  ·  recording_mode (AMBIENT | DICTATION)  ·  context_packet  ·  audio_segments  ·  transcript  ·  generated_note  ·  final_note  ·  delivery_result  ·  errors[]  ·  EncounterMetrics (timing, ASR conf, note conf)</font>> fillcolor="#EEF2FF" fontcolor="#1E1B4B" fontname=Helvetica fontsize=9 height=0.55 shape=rectangle style=filled width=15.5]
		{
			rank=same
		}
		ctx -> estate [style=invis]
	}
	subgraph cluster_mcp {
		color="#00B27A" fillcolor="#F0FDF4" fontname="Helvetica-Bold" fontsize=12 label="§2  MCP ENGINE REGISTRY & SERVERS  (mcp_servers/)" labeljust=l labelloc=t penwidth=2 style=filled
		reg [label=<<b>EngineRegistry</b><br/><font point-size="8">mcp_servers/registry.py<br/>get_asr() · get_llm() · get_ehr()<br/>get_asr_for_provider(provider_id, use_lora=False)<br/>get_with_failover() · health_check_all()<br/>Config: config/engines.yaml</font>> fillcolor="#00B27A" fontcolor=white fontname="Helvetica-Bold" fontsize=10 shape=box style="filled,rounded" width=3.4]
		subgraph cluster_asr {
			color="#00B27A" fillcolor="#DCFCE7" fontname="Helvetica-Bold" fontsize=10 label="ASR Servers" style=filled
			asr_wx [label=<<b>[DEFAULT] WhisperXServer</b><br/><font point-size="8">faster-whisper (CTranslate2)</font><br/><font point-size="8">pyannote 3.1 · wav2vec2 alignment</font><br/><font point-size="8">Model: whisper-large-v3 · CUDA</font><br/><font point-size="8">VRAM peak 10-12 GB (A10G 23 GB)</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=2.6]
			asr_lora [label=<<b>[OPT-IN] WhisperXLoraServer</b><br/><font point-size="8">peft LoRA adapter</font><br/><font point-size="8">Requires ≥30 min verbatim audio</font><br/><font point-size="8">Ambient: -11-13% WER improvement</font>> color="#64748B" fillcolor="#E2E8F0" fontcolor="#64748B" fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded,dashed" width=2.6]
		}
		subgraph cluster_llm {
			color="#00B27A" fillcolor="#DCFCE7" fontname="Helvetica-Bold" fontsize=10 label="LLM Servers" style=filled
			llm_ol [label=<<b>[DEFAULT] OllamaServer</b><br/><font point-size="8">OpenAI-compat · localhost:11434/v1</font><br/><font point-size="8">qwen2.5:14b (Apache 2.0) · ~8 GB VRAM</font><br/><font point-size="8">keep_alive=0 (VRAM sharing)</font><br/><font point-size="8">note_generation / coding / summary</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=2.6]
			llm_fut [label=<<b>[FUTURE] vLLM / Claude / OpenAI</b><br/><font point-size="8">Same LLMEngine interface</font><br/><font point-size="8">Zero pipeline code changes</font>> color="#64748B" fillcolor="#E2E8F0" fontcolor="#64748B" fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded,dashed" width=2.6]
		}
		subgraph cluster_ehr {
			color="#D97706" fillcolor="#FEF9C3" fontname="Helvetica-Bold" fontsize=10 label="EHR Adapters" style=filled
			ehr_stub [label=<<b>[DEFAULT] StubEHRServer</b><br/><font point-size="8">Reads patient_context.yaml</font><br/><font point-size="8">get_patient() · get_problem_list()</font><br/><font point-size="8">get_medications() · get_allergies()</font><br/><font point-size="8">get_recent_labs() · push_note()</font>> color="#D97706" fillcolor="#D97706" fontcolor=white fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=2.6]
			ehr_fut [label=<<b>[FUTURE] FHIRServer (R4) / HL7v2</b><br/><font point-size="8">Same EHRAdapter interface</font><br/><font point-size="8">Browser extension bridge</font>> color="#64748B" fillcolor="#E2E8F0" fontcolor="#64748B" fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded,dashed" width=2.6]
		}
		subgraph cluster_data {
			color="#00B27A" fillcolor="#DCFCE7" fontname="Helvetica-Bold" fontsize=10 label="Data Servers" style=filled
			tpl_srv [label=<<b>TemplateServer</b><br/><font point-size="8">config/templates/*.yaml</font><br/><font point-size="8">get_template(specialty, visit_type)</font><br/><font point-size="8">ortho_follow_up · soap_default · …</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=2.6]
			dict_srv [label=<<b>MedicalDictServer</b><br/><font point-size="8">get_hotwords(specialty, max_terms)</font><br/><font point-size="8">98K OpenMedSpel base dictionary</font><br/><font point-size="8">Specialty: ortho · cardiology · …</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=2.6]
		}
		{
			rank=same
		}
		reg -> asr_wx [label=ASR fontsize=8 lhead=cluster_asr]
		reg -> asr_lora [color="#64748B" fontsize=8 style=dashed]
		reg -> llm_ol [label=LLM fontsize=8 lhead=cluster_llm]
		reg -> llm_fut [color="#64748B" fontsize=8 style=dashed]
		reg -> ehr_stub [label=EHR fontsize=8 lhead=cluster_ehr]
		reg -> ehr_fut [color="#64748B" fontsize=8 style=dashed]
		reg -> tpl_srv [fontsize=8]
		reg -> dict_srv [fontsize=8]
	}
	subgraph cluster_support {
		color="#D97706" fillcolor="#FFFBEB" fontname="Helvetica-Bold" fontsize=12 label="§3  SUPPORTING COMPONENTS" labeljust=l labelloc=t penwidth=2 style=filled
		postproc [label=<<b>Post-Processor  (postprocessor/)</b><br/><font point-size="8">medasr_postprocessor.py · 12-stage rule-based pipeline</font><br/><font point-size="8">medical_wordlist.txt · 98K OpenMedSpel (GPL)</font><br/><font point-size="8">Called by: transcribe_node._apply_postprocessor()</font><br/><font point-size="8">CTC stutter pairs -90% · char stutters -99%</font><br/><font point-size="8">Medical term correction -87% · artifact removal</font>> fillcolor="#FFFBEB" fontcolor="#1C1917" fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=3.1]
		prov_mgr [label=<<b>Provider Profile System  (config/providers/)</b><br/><font point-size="8">config/providers/{provider_id}.yaml per provider</font><br/><font point-size="8">style_directives · custom_vocabulary (22 terms)</font><br/><font point-size="8">asr_overrides · template_routing · quality_history</font><br/><font point-size="8">ProviderManager.resolve_template(provider_id, visit_type)</font><br/><font point-size="8">Dr. Faraz Rahman: 10 directives, 22 vocab, 4 routing entries</font>> fillcolor="#FFFBEB" fontcolor="#1C1917" fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=3.1]
		{
			rank=same
		}
		tpl_sys [label=<<b>Template System  (config/templates/*.yaml)</b><br/><font point-size="8">ortho_follow_up (6 sections) · dictation short follow-ups</font><br/><font point-size="8">ortho_initial_eval (12 sections) · ambient initial encounters</font><br/><font point-size="8">soap_default · specialty-specific templates</font><br/><font point-size="8">Each: sections (label, required, prompt_hint), formatting</font><br/><font point-size="8">Routing: provider_id + visit_type → template_id → YAML</font>> fillcolor="#FFFBEB" fontcolor="#1C1917" fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=3.1]
		qual_fw [label=<<b>Quality Evaluation  (quality/)</b><br/><font point-size="8">evaluator.py · LLM-as-judge: always use llama3.1:latest as judge</font><br/><font point-size="8">fact_extractor.py · meds / diagnoses / exam findings</font><br/><font point-size="8">Dimensions: accuracy · completeness · no_hallucination</font><br/><font point-size="8">            structure · language  (each 1–5, weighted)</font><br/><font point-size="8">report.py → quality_report_v{N}.md per version</font>> fillcolor="#FFFBEB" fontcolor="#1C1917" fontname=Helvetica fontsize=9 margin="0.12,0.07" shape=box style="filled,rounded" width=3.1]
		{
			rank=same
		}
		qual_trend [label=<<b>Quality Progress  (v1 → v6)</b><br/><font point-size="8">v1  Session 4  basic pipeline         ~3.50 / 5.0<br/>v2  Session 5  templates + dicts        4.30 / 5.0<br/>v3  Session 7  EHR context              4.34 / 5.0<br/>v4  Session 8  provider profiles        4.38 / 5.0<br/>v5  Session 10 ASR knobs wired          4.35 / 5.0<br/><b>v6  Model upgrade  qwen2.5:14b      4.44 / 5.0  ✓ current</b><br/><font point-size="7">Judge: llama3.1:latest · 22 gold-standard samples</font></font>> fillcolor="#F8FAFC" fontcolor="#1C1917" fontname=Helvetica fontsize=9 shape=box style="filled,rounded" width=5.8]
		prov_mgr -> tpl_sys [label=resolves fontsize=8]
		qual_fw -> qual_trend [fontsize=8]
	}
	subgraph cluster_ui {
		color="#0369A1" fillcolor="#DBEAFE" fontname="Helvetica-Bold" fontsize=12 label="§4  API + WEB UI" labeljust=l labelloc=t penwidth=2 style=filled
		api [label=<<b>FastAPI Backend  (api/)</b><br/><font point-size="8"><b>Encounters:</b>  POST /encounters  ·  POST /{id}/upload<br/>GET /{id}  ·  GET /{id}/transcript  ·  GET /{id}/note<br/>GET /{id}/audio  ·  GET /{id}/comparison  ·  GET /{id}/quality<br/><b>Providers:</b>  GET /providers  ·  GET /{id}/quality-trend<br/><b>Quality:</b>  GET /quality/aggregate · /samples · /dimensions<br/><b>WebSocket:</b>  WS /ws/encounters/{id} — real-time progress<br/><b>Data source:</b>  output/ directory tree (no DB yet)</font>> fillcolor="#0369A1" fontcolor=white fontname="Helvetica-Bold" fontsize=9 shape=box style="filled,rounded" width=5.0]
		web [label=<<b>Next.js Web App  (client/web/)</b><br/><font point-size="8"><b>Dashboard (/):</b>  KPI cards · quality trend (Recharts) · encounters table<br/><b>Samples (/samples):</b>  filterable table (version, mode, score range)<br/><b>Sample Detail (/samples/[id])  —  6 tabs:</b><br/>  Transcript: HTML5 audio player + version picker (v1–v6)<br/>  Clinical Note: rendered Markdown + version picker<br/>  Comparison: gold vs generated side-by-side<br/>  Gold Standard: original gold-standard note<br/>  Quality Scores: dimension bar chart + fact-check table<br/>  Compare Versions: dual pickers + LCS line diff (green/red/gray)<br/><b>Providers (/providers):</b>  cards with quality badge<br/><b>Upload (/upload):</b>  drag-and-drop MP3/WAV + provider selector</font>> fillcolor="#0369A1" fontcolor=white fontname="Helvetica-Bold" fontsize=9 shape=box style="filled,rounded" width=5.0]
		{
			rank=same
		}
		web -> api [label="REST calls" fontsize=8]
		api -> web [label="JSON + WebSocket" fontsize=8 style=dashed]
	}
	subgraph cluster_legend {
		color="#CBD5E1" fillcolor="#F8FAFC" fontname=Helvetica fontsize=10 label=Legend labeljust=r labelloc=b style=filled
		l1 [label="[DEFAULT]  active implementation — solid border" fontsize=9 shape=plaintext]
		l2 [label="[OPT-IN / FUTURE]  planned or stubbed — dashed border" fontsize=9 shape=plaintext]
		l3 [label="──►  data flow          - - ►  optional / future path" fontsize=9 shape=plaintext]
		l1 -> l2 [style=invis]
		l2 -> l3 [style=invis]
	}
	estate -> reg [style=invis]
	reg -> postproc [style=invis]
	postproc -> api [style=invis]
	qual_fw -> api [style=invis]
	ctx -> ehr_stub [label="get_patient()" color="#D97706" constraint=false fontsize=8 style=dashed]
	tx -> asr_wx [label="transcribe_batch_sync()" color="#00B27A" constraint=false fontsize=8 style=dashed]
	tx -> postproc [label="_apply_postprocessor()" color="#D97706" constraint=false fontsize=8 style=dashed]
	note -> llm_ol [label="generate_sync()" color="#00B27A" constraint=false fontsize=8 style=dashed]
	note -> tpl_srv [label="load_template()" color="#00B27A" constraint=false fontsize=8 style=dashed]
	note -> dict_srv [label="get_hotwords()" color="#00B27A" constraint=false fontsize=8 style=dashed]
	del -> ehr_stub [label="push_note()" color="#D97706" constraint=false fontsize=8 style=dashed]
	del -> api [label="writes output/" color="#0369A1" constraint=false fontsize=8 style=dashed]
}
