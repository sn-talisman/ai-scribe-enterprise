digraph ai_scribe {
	bgcolor=white compound=true dpi=150 fontname=Helvetica fontsize=12 nodesep=0.40 pad=0.6 rankdir=TB ranksep=0.55
	{
		rank=same
		ctx [label=<<b>CONTEXT</b><br/><font point-size="9">Load patient context</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=11 height=0.7 margin="0.12,0.08" shape=box style="filled,rounded" width=2.0]
		ehr_stub [label=<<b>StubEHRServer  (mcp_servers/ehr/)</b><br/><font point-size="9">Reads patient_context.yaml per sample</font><br/><font point-size="9">get_patient() · get_problem_list()</font><br/><font point-size="9">get_medications() · get_allergies()</font><br/><font point-size="9">[FUTURE] FHIRServer (R4) — same interface</font>> color="#B45309" fillcolor="#B45309" fontcolor=white fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
	}
	{
		rank=same
		cap [label=<<b>CAPTURE</b><br/><font point-size="9">Audio I/O · VAD · noise suppress</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=11 height=0.7 margin="0.12,0.08" shape=box style="filled,rounded" width=2.0]
		cap_tools [label=<<b>Audio Tools  (mcp_servers/audio/)</b><br/><font point-size="9">Silero VAD — silence detection</font><br/><font point-size="9">DeepFilterNet — noise suppression</font><br/><font point-size="9">ffmpeg — format conversion</font><br/><font point-size="9">[FUTURE] NeMo streaming ASR</font>> color="#78716C" fillcolor="#F8FAFC" fontcolor="#1C1917" fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
	}
	{
		rank=same
		tx [label=<<b>TRANSCRIBE</b><br/><font point-size="9">ASR · diarization · post-process</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=11 height=0.7 margin="0.12,0.08" shape=box style="filled,rounded" width=2.0]
		asr_wx [label=<<b>WhisperXServer  (mcp_servers/asr/)  [DEFAULT]</b><br/><font point-size="9">faster-whisper · CTranslate2 · CUDA · VRAM ≈ 10–12 GB</font><br/><font point-size="9">Model: whisper-large-v3 · beam_size=5</font><br/><font point-size="9">pyannote 3.1 diarization · wav2vec2 word alignment</font><br/><font point-size="9">condition_on_previous_text: True (dictation) / False (ambient)</font><br/><font point-size="9">hotwords: top-100 provider vocab (logit boost)</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
		postproc [label=<<b>PostProcessor  (postprocessor/)</b><br/><font point-size="9">medasr_postprocessor.py · 12-stage rule-based</font><br/><font point-size="9">98 K OpenMedSpel dictionary (GPL)</font><br/><font point-size="9">CTC stutter −90% · char stutter −99% · term fix −87%</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
	}
	{
		rank=same
		asr_r [label=<<font point-size="9">asr_router</font>> fillcolor="#312E81" fontcolor=white fontsize=9 height=0.55 shape=diamond style=filled width=0.8]
		asr_lora [label=<<b>WhisperXLoraServer  [OPT-IN]</b><br/><font point-size="9">peft LoRA (r=8) · use_lora=True in registry</font><br/><font point-size="9">Ambient: −11–13 % WER · Dictation: NOT ready</font><br/><font point-size="9">Requires ≥ 30 min verbatim audio per provider</font><br/><font point-size="9">models/whisper_lora/{provider_id}/</font>> color="#475569" fillcolor="#E2E8F0" fontcolor="#475569" fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded,dashed" width=3.8]
	}
	{
		rank=same
		note [label=<<b>NOTE</b><br/><font point-size="9">Prompt assembly · LLM · parse</font>> fillcolor="#1E1B4B" fontcolor=white fontname="Helvetica-Bold" fontsize=11 height=0.7 margin="0.12,0.08" shape=box style="filled,rounded" width=2.0]
		llm_ol [label=<<b>OllamaServer  (mcp_servers/llm/)  [DEFAULT]</b><br/><font point-size="9">OpenAI-compat · localhost:11434/v1 · keep_alive=0</font><br/><font point-size="9">qwen2.5:14b (Apache 2.0) · VRAM ≈ 8 GB</font><br/><font point-size="9">Tasks: note_generation · coding · patient_summary</font><br/><font point-size="9">[FUTURE] vLLM / Claude / OpenAI — same LLMEngine interface</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
		tpl_srv [label=<<b>TemplateServer  (mcp_servers/data/)</b><br/><font point-size="9">config/templates/*.yaml · get_template(specialty, visit_type)</font><br/><font point-size="9">ortho_follow_up (6 §) · ortho_initial_eval (12 §) · soap_default</font><br/><font point-size="9">Routing: provider_id + visit_type → YAML → section prompts</font>> color="#00B27A" fillcolor="#00B27A" fontcolor=white fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
	}
	{
		rank=same
