		qual_fw [label=<<b>Quality Framework  (quality/)</b><br/><font point-size="9">LLM-as-judge: always llama3.1:latest (cross-model fair eval)</font><br/><font point-size="9">Dimensions: accuracy · completeness · no-hallucination</font><br/><font point-size="9">            structure · clinical language  (each 1–5)</font><br/><font point-size="9">fact_extractor: meds / diagnoses / exam findings precision/recall</font>> color="#6D28D9" fillcolor="#F8FAFC" fontcolor="#1C1917" fontname="Helvetica-Bold" fontsize=10 margin="0.14,0.09" shape=box style="filled,rounded" width=3.8]
	}
	{
		rank=same
